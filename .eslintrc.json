{
    "env": {
        "browser": true,
        "node": true,
        "commonjs": true,
        "es2021": true
    },
    "extends": "eslint:recommended",
    "plugins": ["simple-import-sort"],
    "parserOptions": {
        "ecmaVersion": "latest"
    },
    "rules": {
        "indent": ["warn", 4],
        "no-empty": "off",
        "no-unused-vars": "warn",
        "simple-import-sort/imports": "warn",
        "simple-import-sort/exports": "warn"
    },
    "overrides": [
        {
            "files": ["**/*.spec.js", "**/*.spec.jsx"],
            "env": {
                "jest": true
            }
        }
    ]
}
